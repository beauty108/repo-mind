# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://repomind:repomind@localhost:5432/repomind

# ── Redis (Celery broker + result cache) ───────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Embedding Configuration ────────────────────────────────────────────────────
# Options: local | openai
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Optional: only required if EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# ── LLM Configuration ──────────────────────────────────────────────────────────
# Options: gemini (only provider implemented; others are future work)
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here

# Current free-tier model as of June 2026. Change if Google updates the lineup.
# Verify available models at: https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL=gemini-2.5-flash

# ── Repository Ingestion Limits ────────────────────────────────────────────────
# Hard cap on cloned repository size in megabytes
MAX_REPO_SIZE_MB=500
# Maximum seconds allowed for a git clone operation
CLONE_TIMEOUT_SECONDS=120

# ── Retrieval / RAG ────────────────────────────────────────────────────────────
# Number of chunks retrieved per query
TOP_K=8
# Maximum chunks passed to the LLM prompt (separate from TOP_K for future reranking)
MAX_CONTEXT_CHUNKS=8

# ── CORS (comma-separated origins for the frontend dev server) ─────────────────
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# ── Rate Limiting ──────────────────────────────────────────────────────────────
# POST /api/repos: max indexing submissions per minute per IP
RATE_LIMIT_INDEX=5/minute
# POST /api/repos/{id}/chat: max chat requests per minute per IP
RATE_LIMIT_CHAT=10/minute

# ── Cache ──────────────────────────────────────────────────────────────────────
# TTL (seconds) for chat response cache (0 to disable)
CHAT_CACHE_TTL=300
